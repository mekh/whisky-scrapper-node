# Configuration for scripts/db-backup.sh — copy to db-backup.env and edit.
# This file is sourced as Bash, so you may use shell expansions here.
#
# NOTE: the script runs in safe mode by default (nothing is deleted or dropped;
# destructive steps are only printed). Pass --safe=false on the command line to
# actually prune old dumps / recreate the DB on restore — e.g. cron must use
# `backup --safe=false` for pruning to happen. Safe mode is a flag, not config.
#
#   cp scripts/db-backup.env.example scripts/db-backup.env
#
# The real db-backup.env is git-ignored because it holds the DB password;
# keep it chmod 600. Values are validated at startup: paths/names may only use
# [A-Za-z0-9._/-] — no spaces, globs (* ? [ ]), quotes or semicolons — so a typo
# like a trailing space is rejected before any deletion. MAX_BACKUPS must be >=1.

# --- SFTP destination (auth is by SSH key via ~/.ssh/config) ---------------
# Login as user@host. Put IdentityFile / Port / real HostName in ~/.ssh/config.
SFTP_TARGET="backup@backups.example.com"
# Absolute directory on the SFTP host where dumps are stored (created if absent).
REMOTE_DIR="/srv/backups/whisky"
# Optional: override the SSH port (prefer setting it in ~/.ssh/config instead).
# SFTP_PORT="2222"

# --- Retention -------------------------------------------------------------
# File name prefix; dumps are <prefix>_<UTC-timestamp>.dump. Defaults to DB_NAME.
BACKUP_PREFIX="whisky"
# How many dumps to keep. After each successful upload, older ones are deleted.
MAX_BACKUPS="14"

# --- Database credentials --------------------------------------------------
# Set them here, or reuse the values already in be/.env by uncommenting:
#   set -a; . "$BE_DIR/.env"; set +a
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="whisky"
DB_USER="whisky"
DB_PASS="change-me"

# --- Restore: recreating the target database -------------------------------
# `restore` drops and recreates DB_NAME. That connects to a maintenance
# database as a role allowed to DROP/CREATE it. Both default to the values
# above (the compose bootstrap DB_USER is a superuser); override only if a
# separate admin role is needed.
# DB_MAINT="postgres"
# ADMIN_USER="postgres"
# ADMIN_PASS="change-me"

# --- Optional: version-matched client binaries -----------------------------
# Point these at the PostgreSQL 18 client tools if they are not the default on
# PATH (their major version must match the server).
# PGDUMP_BIN="/usr/lib/postgresql/18/bin/pg_dump"
# PGRESTORE_BIN="/usr/lib/postgresql/18/bin/pg_restore"
# PSQL_BIN="/usr/lib/postgresql/18/bin/psql"
